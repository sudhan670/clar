<!DOCTYPE html>
<html>
<head>
  <title>Meeting Room Booking</title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag 'application', media: 'all' %>
  <%= javascript_include_tag 'application' %>

  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: #f5f7fb;
    }

    /* Navbar */
    .navbar {
      background: linear-gradient(135deg, #4f46e5, #3b82f6);
      padding: 12px 0;
    }

    .navbar-brand {
      font-weight: 600;
      color: #fff !important;
      font-size: 1.4rem;
    }

    .nav-link {
      color: rgba(255,255,255,0.85) !important;
      transition: 0.3s;
      margin-right: 10px;
    }

    .nav-link:hover {
      color: #fff !important;
      transform: translateY(-1px);
    }

    /* Buttons */
    .btn {
      transition: all 0.2s ease-in-out;
      border-radius: 20px;
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    /* Container spacing */
    .container {
      max-width: 1100px;
    }

    /* Alerts */
    .alert {
      border-radius: 12px;
    }

    /* Card styling */
    .card {
      border: none;
      border-radius: 16px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.06);
    }

    .card-header {
      background: #fff;
      border-bottom: 1px solid #eee;
      font-weight: 600;
    }

    /* Footer */
    .footer {
      margin-top: 50px;
      padding: 20px;
      text-align: center;
      color: #777;
      font-size: 14px;
    }
  </style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
  <div class="container">

    <%= link_to "Meeting Room Booking", root_path, class: "navbar-brand" %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <%= link_to "Rooms", rooms_path, class: "nav-link" %>
        </li>

        <li class="nav-item">
          <%= link_to "My Bookings", bookings_path, class: "nav-link" %>
        </li>

        <% if current_user&.admin? %>
          <li class="nav-item">
            <%= link_to "Admin Dashboard", admin_dashboard_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>

      <ul class="navbar-nav align-items-center">
        <% if user_signed_in? %>
          <li class="nav-item me-2 text-white">
            <strong><%= current_user.name %></strong>
            <small>(<%= current_user.position %>)</small>
          </li>

          <li class="nav-item">
            <%= button_to "Sign out",
                destroy_user_session_path,
                method: :delete,
                class: "btn btn-light btn-sm px-3" %>
          </li>

        <% else %>
          <li class="nav-item me-2">
            <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-light btn-sm" %>
          </li>

          <li class="nav-item">
            <%= link_to "Register", new_user_registration_path, class: "btn btn-light btn-sm" %>
          </li>
        <% end %>
      </ul>

    </div>
  </div>
</nav>

<!-- MAIN CONTENT -->
<div class="container mt-4">

  <% if notice %>
    <div class="alert alert-success shadow-sm"><%= notice %></div>
  <% end %>

  <% if alert %>
    <div class="alert alert-danger shadow-sm"><%= alert %></div>
  <% end %>

  <%= yield %>
</div>

<!-- FOOTER -->
<div class="footer">
  © <%= Time.current.year %> Meeting Room Booking System • Built by Sudhan
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>