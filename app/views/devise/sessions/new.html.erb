<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
  <div class="card p-4 shadow-lg border-0 rounded-4" style="width: 100%; max-width: 420px;">

    <h3 class="text-center mb-4 fw-semibold">Welcome Back 👋</h3>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-inputs">

        <%= f.input :email,
              required: false,
              autofocus: true,
              label: "Email",
              input_html: {
                class: "form-control rounded-3",
                placeholder: "Enter your email"
              } %>

        <%= f.input :password,
              required: false,
              label: "Password",
              input_html: {
                class: "form-control rounded-3",
                placeholder: "Enter your password"
              } %>

        <% if devise_mapping.rememberable? %>
          <div class="form-check mt-2">
            <%= f.check_box :remember_me, class: "form-check-input" %>
            <%= f.label :remember_me, class: "form-check-label small" %>
          </div>
        <% end %>

      </div>

      <div class="form-actions mt-4">
        <%= f.button :submit, "Log in",
              class: "btn btn-primary w-100 rounded-pill py-2" %>
      </div>

    <% end %>

    <div class="text-center mt-3 small">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>