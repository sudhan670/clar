<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-header">
          <h2 class="mb-0">Create New Booking</h2>
        </div>

    <%= form_with(model: @booking, local: true, class: "card-body") do |form| %>

      <% if @booking.errors.any? %>
        <div class="alert alert-danger">
          <h5><%= pluralize(@booking.errors.count, "error") %> prevented saving:</h5>
          <ul class="mb-0">
            <% @booking.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Room Selection -->
      <div class="mb-3">
        <%= form.label :room_id, class: "form-label" %>
        <%= form.collection_select :room_id,
            @rooms,
            :id,
            :name,
            { prompt: "Select a Room" },
            { class: "form-select", required: true } %>
      </div>

      <!-- Time & Duration -->
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :start_time, class: "form-label" %>
          <%= form.datetime_local_field :start_time,
              class: "form-control",
              required: true,
              min: Time.current.strftime("%Y-%m-%dT%H:%M") %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :duration_in_hours, class: "form-label" %>
          <%= form.number_field :duration_in_hours,
              class: "form-control",
              min: 1,
              max: 4,
              required: true %>
        </div>
      </div>

      <!-- Participants -->
      <div class="mb-3">
        <%= form.label :participant_ids, "Participants", class: "form-label" %>
        <%= form.collection_select :participant_ids,
            @users,
            :id,
            :name,
            {},
            {
              class: "form-select",
              multiple: true,
              data: { select2: true }
            } %>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description,
            class: "form-control",
            rows: 3 %>
      </div>

      <!-- Actions -->
      <div class="d-flex justify-content-end gap-2">
        <%= link_to "Cancel", bookings_path, class: "btn btn-secondary btn-grey rounded-pill px-3" %>

        <%= form.submit "Create Booking",
            class: "btn btn-primary rounded-pill px-3",
            data: { disable_with: "Creating..." } %>
      </div>

    <% end %>
  </div>
</div>

  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  if (window.jQuery && $.fn.select2) {
    $('[data-select2]').select2({
      placeholder: "Select participants",
      width: '100%'
    });
  }
});
</script>
