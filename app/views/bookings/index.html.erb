<div class="container py-4">
  <h2 class="fw-bold mb-4">My Bookings</h2>

  <!-- Tabs -->
  <ul class="nav nav-pills mb-4 gap-2">
    <li class="nav-item">
      <a class="nav-link active" data-bs-toggle="tab" href="#upcoming">Upcoming</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#past">Past</a>
    </li>

    <% if current_user.meeting_participants.pending.any? %>
      <li class="nav-item">
        <a class="nav-link position-relative" data-bs-toggle="tab" href="#invitations">
          Pending Invitations
          <span class="badge bg-warning ms-1">
            <%= current_user.meeting_participants.pending.count %>
          </span>
        </a>
      </li>
    <% end %>
  </ul>

  <div class="tab-content">

    <!-- UPCOMING -->
    <div class="tab-pane fade show active" id="upcoming">
      <% upcoming_bookings = @bookings.upcoming.order(start_time: :asc) %>

      <% if upcoming_bookings.any? %>
        <div class="row g-4">
          <% upcoming_bookings.each do |booking| %>
            <div class="col-md-6 col-lg-4">
              <div class="card booking-card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column">

                  <h5 class="fw-semibold mb-2"><%= booking.room.name %></h5>

                  <p class="text-muted mb-1">
                    📅 <%= booking.start_time.to_date %>
                  </p>

                  <p class="text-muted mb-2">
                    ⏰ <%= booking.start_time.strftime("%H:%M") %> -
                    <%= booking.end_time.strftime("%H:%M") %>
                  </p>

                  <!-- Status (unchanged logic) -->
                  <span class="badge mb-3 align-self-start bg-<%= 
                    booking.status == 'confirmed' ? 'success' : 
                    (booking.status == 'canceled' ? 'danger' : 'warning') 
                  %>">
                    <%= booking.status %>
                  </span>

                  <!-- Actions -->
                  <div class="mt-auto d-flex gap-2">
                    <%= link_to "View", booking_path(booking),
                        class: "btn btn-outline-primary btn-sm w-100" %>

                    <% if booking.can_cancel? %>
                      <%= link_to "Cancel", booking_path(booking),
                          method: :delete,
                          data: { confirm: "Are you sure you want to cancel this booking?" },
                          class: "btn btn-outline-danger btn-sm w-100" %>
                    <% end %>
                  </div>

                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <h5>No upcoming bookings</h5>
          <p class="text-muted">Book a room to get started</p>
        </div>
      <% end %>
    </div>

    <!-- PAST -->
    <div class="tab-pane fade" id="past">
      <% past_bookings = @bookings.past.order(start_time: :desc) %>

      <% if past_bookings.any? %>
        <div class="row g-4">
          <% past_bookings.each do |booking| %>
            <div class="col-md-6 col-lg-4">
              <div class="card booking-card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column">

                  <h5 class="fw-semibold mb-2"><%= booking.room.name %></h5>

                  <p class="text-muted mb-1">
                    📅 <%= booking.start_time.to_date %>
                  </p>

                  <p class="text-muted mb-2">
                    ⏰ <%= booking.start_time.strftime("%H:%M") %> -
                    <%= booking.end_time.strftime("%H:%M") %>
                  </p>

                  <span class="badge bg-<%= 
                    booking.status == 'confirmed' ? 'success' : 
                    (booking.status == 'canceled' ? 'danger' : 'warning') 
                  %> mb-3">
                    <%= booking.status %>
                  </span>

                  <%= link_to "View", booking_path(booking),
                      class: "btn btn-outline-primary btn-sm w-100 mt-auto" %>

                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <h5>No past bookings</h5>
        </div>
      <% end %>
    </div>

    <!-- INVITATIONS -->
    <div class="tab-pane fade" id="invitations">
      <% invitations = current_user.meeting_participants.pending.includes(booking: [:room, :user]) %>

      <% if invitations.any? %>
        <div class="list-group">
          <% invitations.each do |invitation| %>
            <% booking = invitation.booking %>

            <div class="list-group-item invitation-card d-flex justify-content-between align-items-center mb-3">

              <div>
                <h6 class="mb-1 fw-semibold"><%= booking.room.name %></h6>

                <small class="text-muted d-block">
                  📅 <%= booking.start_time.to_date %>
                </small>

                <small class="text-muted d-block">
                  ⏰ <%= booking.start_time.strftime("%H:%M") %>
                </small>

                <small class="text-muted">
                  👤 <%= booking.user.name %> (<%= booking.user.position %>)
                </small>
              </div>

              <div class="d-flex gap-2">
                <%= form_with model: invitation,
                  url: meeting_participant_path(invitation),
                  method: :patch,
                  local: true do |form| %>

                  <%= form.hidden_field :status, value: 'accepted' %>
                  <%= form.submit "Accept", class: "btn btn-success btn-sm" %>
                <% end %>

                <%= form_with model: invitation,
                  url: meeting_participant_path(invitation),
                  method: :patch,
                  local: true do |form| %>

                  <%= form.hidden_field :status, value: 'rejected' %>
                  <%= form.submit "Reject", class: "btn btn-outline-danger btn-sm" %>
                <% end %>
              </div>

            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <h5>No pending invitations</h5>
        </div>
      <% end %>
    </div>

  </div>
</div>