<div class="container py-4">
  <h2 class="fw-bold mb-4">My Bookings</h2>

  <% pending_count = @invitations.size %>

  <!-- TABS -->
  <ul class="nav nav-pills mb-4 gap-2" role="tablist" data-turbo="false">

    <!-- PENDING FIRST -->
    <li class="nav-item">
      <button id="invitations-tab"
              class="nav-link active"
              data-bs-toggle="tab"
              data-bs-target="#invitations"
              type="button">
        Pending Invitations
        <% if pending_count > 0 %>
          <span class="badge bg-warning ms-1" style="pointer-events:none;">
            <%= pending_count %>
          </span>
        <% end %>
      </button>
    </li>

    <!-- UPCOMING -->
    <li class="nav-item">
      <button id="upcoming-tab"
              class="nav-link"
              data-bs-toggle="tab"
              data-bs-target="#upcoming"
              type="button">
        Upcoming
      </button>
    </li>

    <!-- PAST -->
    <li class="nav-item">
      <button id="past-tab"
              class="nav-link"
              data-bs-toggle="tab"
              data-bs-target="#past"
              type="button">
        Past
      </button>
    </li>

  </ul>

  <!-- TAB CONTENT -->
  <div class="tab-content">

    <!-- 🔥 INVITATIONS (DEFAULT ACTIVE) -->
    <div class="tab-pane fade show active" id="invitations">

      <% if @invitations.any? %>
        <div class="list-group">

          <% @invitations.each do |invitation| %>
            <% booking = invitation.booking %>

            <div class="list-group-item d-flex justify-content-between align-items-center mb-3">

              <div>
                <h6 class="fw-semibold"><%= booking.room.name %></h6>

                <small class="text-muted d-block">
                  📅 <%= booking.start_time.to_date %>
                </small>

                <small class="text-muted d-block">
                  ⏰ <%= booking.start_time.strftime("%H:%M") %> –
                     <%= booking.end_time.strftime("%H:%M") %>
                </small>

                <small class="text-muted">
                  👤 <%= booking.user.name %> (<%= booking.user.position %>)
                </small>
              </div>

             <div class="d-flex gap-2">

  <!-- ACCEPT -->
  <%= form_with model: invitation,
        url: meeting_participant_path(invitation),
        method: :patch,
        data: { turbo: false } do |f| %>

    <%= f.hidden_field :status, value: "accepted" %>
    <%= f.submit "Accept", class: "btn btn-success btn-sm" %>

  <% end %>

  <!-- REJECT -->
  <%= form_with model: invitation,
        url: meeting_participant_path(invitation),
        method: :patch,
        data: { turbo: false } do |f| %>

    <%= f.hidden_field :status, value: "rejected" %>
    <%= f.submit "Reject", class: "btn btn-outline-danger btn-sm" %>

  <% end %>

</div>
            </div>
          <% end %>

        </div>
      <% else %>
        <div class="text-center py-5">
          <h5>No pending invitations</h5>
        </div>
      <% end %>

    </div>

    <!-- UPCOMING -->
    <div class="tab-pane fade" id="upcoming">

      <% upcoming = @bookings.select { |b| b.start_time > Time.current }.sort_by(&:start_time) %>

      <% if upcoming.any? %>
        <div class="row g-4">
          <% upcoming.each do |booking| %>

            <div class="col-md-6 col-lg-4">
              <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">

                  <h5><%= booking.room.name %></h5>

                  <p class="text-muted">
                    📅 <%= booking.start_time.to_date %>
                  </p>

                  <p class="text-muted">
                    ⏰ <%= booking.start_time.strftime("%H:%M") %> –
                       <%= booking.end_time.strftime("%H:%M") %>
                  </p>

                  <% badge = booking.confirmed? ? "success" :
                              booking.canceled? ? "danger" : "warning" %>

                  <span class="badge bg-<%= badge %> mb-3">
                    <%= booking.status.humanize %>
                  </span>

                  <div class="mt-auto d-flex gap-2">
                    <%= link_to "View",
                          room_booking_path(booking.room, booking),
                          class: "btn btn-outline-primary btn-sm w-100" %>

                    <% if booking.can_cancel? %>
                      <%= link_to "Cancel",
                            room_booking_path(booking.room, booking),
                            data: {
                              turbo_method: :delete,
                              turbo_confirm: "Cancel this booking?"
                            },
                            class: "btn btn-outline-danger btn-sm w-100" %>
                    <% end %>
                  </div>

                </div>
              </div>
            </div>

          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <h5>No upcoming bookings</h5>
        </div>
      <% end %>

    </div>

    <!-- PAST -->
    <div class="tab-pane fade" id="past">

      <% past = @bookings.select { |b| b.start_time <= Time.current }.sort_by(&:start_time).reverse %>

      <% if past.any? %>
        <div class="row g-4">
          <% past.each do |booking| %>

            <div class="col-md-6 col-lg-4">
              <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">

                  <h5><%= booking.room.name %></h5>

                  <p class="text-muted">
                    📅 <%= booking.start_time.to_date %>
                  </p>

                  <p class="text-muted">
                    ⏰ <%= booking.start_time.strftime("%H:%M") %> –
                       <%= booking.end_time.strftime("%H:%M") %>
                  </p>

                  <% badge = booking.confirmed? ? "success" :
                              booking.canceled? ? "danger" : "warning" %>

                  <span class="badge bg-<%= badge %> mb-3">
                    <%= booking.status.humanize %>
                  </span>

                  <%= link_to "View",
                        room_booking_path(booking.room, booking),
                        class: "btn btn-outline-primary btn-sm mt-auto" %>

                </div>
              </div>
            </div>

          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <h5>No past bookings</h5>
        </div>
      <% end %>

    </div>

  </div>
</div>