<h2 class="mb-4 fw-semibold">Admin Dashboard 📊</h2>

<!-- 🔷 Stats Cards -->
<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card p-3 border-0 shadow-sm rounded-4">
      <small class="text-muted">Total Rooms</small>
      <h2 class="fw-bold mb-0"><%= @rooms.count %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-3 border-0 shadow-sm rounded-4">
      <small class="text-muted">Today's Bookings</small>
      <h2 class="fw-bold mb-0 text-success"><%= @today_bookings.count %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-3 border-0 shadow-sm rounded-4">
      <small class="text-muted">Employees</small>
      <h2 class="fw-bold mb-0 text-primary"><%= @users.count %></h2>
    </div>
  </div>
</div>

<!-- 🔷 Rooms + Meetings -->
<div class="row g-4">

  <!-- Rooms -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-header bg-white border-0 fw-semibold">
        Meeting Rooms
      </div>
      <div class="card-body">

        <table class="table align-middle">
          <thead class="text-muted small">
            <tr>
              <th>Name</th>
              <th>Capacity</th>
              <th></th>
            </tr>
          </thead>

          <tbody>
            <% @rooms.each do |room| %>
              <tr>
                <td class="fw-medium"><%= room.name %></td>
                <td><span class="badge bg-light text-dark"><%= room.capacity %></span></td>
                <td class="text-end">
                  <%= link_to "View", room_path(room),
                        class: "btn btn-sm btn-outline-primary rounded-pill px-3" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <%= link_to "➕ Add Room", new_room_path,
              class: "btn btn-primary rounded-pill mt-2" %>
      </div>
    </div>
  </div>

  <!-- Today's Meetings -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-header bg-white border-0 fw-semibold">
        Today's Meetings
      </div>
      <div class="card-body">

        <% if @today_bookings.any? %>
          <table class="table align-middle">
            <thead class="text-muted small">
              <tr>
                <th>Room</th>
                <th>Time</th>
                <th>Status</th>
              </tr>
            </thead>

            <tbody>
              <% @today_bookings.order(start_time: :asc).each do |booking| %>
                <tr>
                  <td><%= booking.room.name %></td>
                  <td class="small">
                    <%= booking.start_time.strftime("%H:%M") %> - 
                    <%= booking.end_time.strftime("%H:%M") %>
                  </td>
                  <td>
                    <span class="badge rounded-pill bg-<%= booking.status == 'confirmed' ? 'success' : (booking.status == 'canceled' ? 'danger' : 'warning') %>">
                      <%= booking.status %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="text-muted small">No meetings today</div>
        <% end %>

      </div>
    </div>
  </div>

</div>

<!-- 🔷 Employee Usage -->
<div class="card border-0 shadow-sm rounded-4 mt-4">
  <div class="card-header bg-white border-0 fw-semibold">
    Employee Booking Usage
  </div>

  <div class="card-body">
    <table class="table align-middle">
      <thead class="text-muted small">
        <tr>
          <th>Name</th>
          <th>Role</th>
          <th>Usage</th>
        </tr>
      </thead>

      <tbody>
        <% @users.each do |user| %>
          <% today_hours = user.daily_booking_hours(Date.today) %>
          <% remaining = [2 - today_hours, 0].max %>

          <tr>
            <td class="fw-medium"><%= user.name %></td>
            <td><span class="badge bg-light text-dark"><%= user.position %></span></td>

            <td style="width: 40%;">
              <div class="progress" style="height: 8px;">
                <div class="progress-bar bg-success"
                     style="width: <%= (today_hours / 2.0) * 100 %>%;">
                </div>
              </div>
              <small class="text-muted">
                <%= today_hours %>h used / <%= remaining %>h left
              </small>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- 🔷 Invitations -->
<div class="card border-0 shadow-sm rounded-4 mt-4">
  <div class="card-header bg-white border-0 fw-semibold">
    Pending Invitations
  </div>

  <div class="card-body">

    <% @pending_invitations = MeetingParticipant.includes(booking: [:room, :user]).pending.order('bookings.start_time') %>

    <% if @pending_invitations.any? %>
      <table class="table align-middle">
        <thead class="text-muted small">
          <tr>
            <th>User</th>
            <th>Room</th>
            <th>Time</th>
          </tr>
        </thead>

        <tbody>
          <% @pending_invitations.each do |invitation| %>
            <% booking = invitation.booking %>

            <tr>
              <td><%= invitation.user.name %></td>
              <td><%= booking.room.name %></td>
              <td class="small">
                <%= booking.start_time.strftime("%d %b, %H:%M") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="alert alert-light text-muted mb-0">
        No pending invitations
      </div>
    <% end %>

  </div>
</div>