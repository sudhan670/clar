<h2 class="mb-4 fw-semibold">Admin Dashboard 📊</h2>

<!-- 🔷 Stats -->
<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card p-3 shadow-sm rounded-4">
      <small class="text-muted">Total Rooms</small>
      <h2><%= @rooms&.count || 0 %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-3 shadow-sm rounded-4">
      <small class="text-muted">Today's Bookings</small>
      <h2 class="text-success"><%= @today_bookings&.count || 0 %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-3 shadow-sm rounded-4">
      <small class="text-muted">Employees</small>
      <h2 class="text-primary"><%= @users&.count || 0 %></h2>
    </div>
  </div>
</div>

<!-- 🔷 Rooms -->
<div class="card shadow-sm rounded-4 mb-4">
  <div class="card-header fw-semibold">Meeting Rooms</div>

  <div class="card-body">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Capacity</th>
          <th></th>
        </tr>
      </thead>

      <tbody>
        <% (@rooms || []).each do |room| %>
          <tr>
            <td><%= room.name || "N/A" %></td>
            <td><%= room.capacity || "-" %></td>
            <td>
              <%= link_to "View", room_path(room), class: "btn btn-sm btn-outline-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%= link_to "Add Room", new_room_path, class: "btn btn-primary" %>
  </div>
</div>

<!-- 🔷 Today's Meetings -->
<div class="card shadow-sm rounded-4 mb-4">
  <div class="card-header fw-semibold">Today's Meetings</div>

  <div class="card-body">
    <% if @today_bookings.present? %>
      <table class="table">
        <thead>
          <tr>
            <th>Room</th>
            <th>Time</th>
            <th>Status</th>
          </tr>
        </thead>

        <tbody>
          <% @today_bookings.each do |booking| %>
            <% status = booking.status.presence || "pending" %>

            <tr>
              <td><%= booking.room&.name || "N/A" %></td>

              <td>
                <%= booking.start_time&.strftime("%H:%M") || "-" %> -
                <%= booking.end_time&.strftime("%H:%M") || "-" %>
              </td>

              <td>
                <span class="badge bg-<%= 
                  status == 'confirmed' ? 'success' : 
                  status == 'canceled' ? 'danger' : 
                  'warning' %>">
                  <%= status %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted">No meetings today</p>
    <% end %>
  </div>
</div>

<!-- 🔷 Employee Usage -->
<div class="card shadow-sm rounded-4 mb-4">
  <div class="card-header fw-semibold">Employee Usage</div>

  <div class="card-body">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Role</th>
          <th>Usage</th>
        </tr>
      </thead>

      <tbody>
        <% (@users || []).each do |user| %>
          <% today_hours = (user.respond_to?(:daily_booking_hours) ? user.daily_booking_hours(Date.today).to_f : 0.0) %>
          <% remaining = [2 - today_hours, 0].max %>

          <tr>
            <td><%= user.name || "N/A" %></td>
            <td><%= user.position || "-" %></td>

            <td style="width: 40%;">
              <div class="progress">
                <div class="progress-bar bg-success"
                     style="width: <%= (today_hours / 2.0 * 100).round(2) %>%;"></div>
              </div>

              <small>
                <%= today_hours.round(2) %>h used / <%= remaining.round(2) %>h left
              </small>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- 🔷 Pending Invitations -->
<div class="card shadow-sm rounded-4">
  <div class="card-header fw-semibold">Pending Invitations</div>

  <div class="card-body">
    <% if @pending_invitations.present? %>
      <table class="table">
        <thead>
          <tr>
            <th>User</th>
            <th>Room</th>
            <th>Time</th>
          </tr>
        </thead>

        <tbody>
          <% @pending_invitations.each do |invitation| %>
            <% booking = invitation.booking %>

            <tr>
              <td><%= invitation.user&.name || "N/A" %></td>
              <td><%= booking&.room&.name || "N/A" %></td>
              <td><%= booking&.start_time&.strftime("%d %b %H:%M") || "-" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted">No pending invitations</p>
    <% end %>
  </div>
</div>